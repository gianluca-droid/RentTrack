<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <!-- Header: Logo + Nome app -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/widget_app_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="RentTrack"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:alpha="0.9" />

        <TextView
            android:id="@+id/widget_update_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--:--"
            android:textColor="#AAAAAA"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Saldo principale -->
    <TextView
        android:id="@+id/widget_saldo_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Saldo"
        android:textColor="#8899AA"
        android:textSize="10sp"
        android:letterSpacing="0.08" />

    <TextView
        android:id="@+id/widget_saldo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="€ ---"
        android:textColor="#00C896"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#22FFFFFF"
        android:layout_marginBottom="8dp" />

    <!-- Riga info: Cedolini aperti + Prossima scadenza -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Cedolini aperti -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Da incassare"
                android:textColor="#8899AA"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/widget_open_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFCC44"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Prossima scadenza -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prossima scadenza"
                android:textColor="#8899AA"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/widget_next_due"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nessuna"
                android:textColor="#DDDDDD"
                android:textSize="11sp"
                android:singleLine="true"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
