<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Richiesto su Android 13+ per mostrare notifiche -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- WorkManager: permesso per eseguire task in background -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Supabase: accesso a Internet per le chiamate API -->
    <uses-permission android:name="android.permission.INTERNET" />


    <application
        android:name=".RentTrackApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CondoGest"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.CondoGest">
            <!-- Launcher principale -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Deep link: renttrack://auth/callback
                 Gestisce: recovery password, email confirmation, OAuth Google callback -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="renttrack"
                    android:host="auth"
                    android:pathPrefix="/callback" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- ── Widget home screen ──────────────────────────────────────── -->
        <receiver
            android:name=".widget.RentTrackWidget"
            android:exported="true"
            android:label="RentTrack Widget"
            android:permission="android.permission.BIND_APPWIDGET">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_rent_track_info" />
        </receiver>

    </application>
</manifest>


